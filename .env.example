# ─────────────────────────────────────────────
#  NOVA — Variables de entorno
#  Copiá este archivo como .env y completá los valores.
#  Nunca subas el .env al repositorio.
# ─────────────────────────────────────────────

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nova_db
DB_USER=
DB_PASSWORD=

# Ollama (modelo local — no requiere API key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (opcional, para usar en lugar de Ollama en el futuro)
# OPENAI_API_KEY=

# Entorno
NODE_ENV=development
